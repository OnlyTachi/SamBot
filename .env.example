# 🤖 Configurações do Bot
DISCORD_TOKEN="seu_token_aqui"
OWNER_ID="seu_id_do_discord"
BOT_PREFIX="+"

# CONFIGURAÇÕES DO FLUXO DE MÚSICA (LAVALINK & NAVIDROME)

# Modo de operação do Bot: 
# HIBRIDO = Busca no Navidrome primeiro. Se não achar, vai para a Internet (Lavalink Online).
# LOCAL   = Busca APENAS no Navidrome (Intranet).
# ONLINE  = Busca APENAS na Internet (YouTube/SoundCloud/etc).
MUSIC_SOURCE_MODE=ONLINE

# --- SERVIDOR LAVALINK LOCAL (Opcional - Usado para tocar o Navidrome sem sair da rede local)
LAVALINK_LOCAL_HOST=127.0.0.1
LAVALINK_LOCAL_PORT=2333
LAVALINK_LOCAL_PASSWORD=youshallnotpass

# --- SERVIDORES LAVALINK ONLINE (Múltiplos servidores separados por vírgula para balanceamento)
LAVALINK_ONLINE_HOSTS=lavalinkv4.serenetia.com,outro-lavalink.com
LAVALINK_ONLINE_PORTS=443,80
LAVALINK_ONLINE_PASSWORDS=https://seretia.link/discord,senha-do-segundo-node

# --- BIBLIOTECA PESSOAL (NAVIDROME)
NAVIDROME_URL=https://seu-navidrome.com
NAVIDROME_USER=seu_usuario
NAVIDROME_PASSWORD=sua_senha

# 🔑 API Keys de Serviços Externos
KLIPY_API_KEY="sua_chave_klipy"
STEAM_API_KEY="sua_chave_steam"
PIXABAY_API_KEY="sua_chave_pixabay"

# 🔍 Google Custom Search API
GOOGLE_SEARCH_API_KEY="sua_chave_google_search"
GOOGLE_SEARCH_CX="seu_id_cx"
YOUTUBE_PLAYLIST_ID="id_da_sua_playlist"

# 🦁 Brave Search API (Backup de busca)
BRAVE_SEARCH_API_KEY="sua_chave_brave"

# 🧠 Google Gemini (Cloud LLM)
GEMINI_MODEL_NAME="gemini-2.0-flash" # Sugerido: flash pela velocidade
GEMINI_API_KEY_1="chave_1"
GEMINI_API_KEY_2="chave_2"
GEMINI_API_KEY_3="chave_3"
GEMINI_API_KEY_4="chave_4"
GEMINI_API_KEY_5="chave_5"

# 🎮 IGDB API (Informações de Jogos)
IGDB_CLIENT_ID="seu_client_id"
IGDB_CLIENT_SECRET="seu_client_secret"

# 🏠 Configurações Ollama (Músculo Local/Remoto via Tailscale)
# Remoto (ex: sua workstation rodando via IP do Tailscale)
OLLAMA_REMOTE_URL="http://ip_tailscale_workstation:11434"
MODEL_SMART_REMOTE="phi3.5:latest"
MODEL_EMBED_REMOTE="nomic-embed-text:latest"

# Local (ex: rodando no mesmo servidor Docker)
OLLAMA_LOCAL_URL="http://host.docker.internal:11434"
MODEL_FAST_LOCAL="qwen2.5:1.5b"
MODEL_EMBED_LOCAL="nomic-embed-text:latest"